{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/supabase-mcp@latest"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@sequential/thinking-mcp@latest"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "shadcn": {
      "command": "npx",
      "args": ["-y", "@shadcn/mcp@latest"],
      "requiresFullConfig": true
    },
    "n8n-mcp": {
      "command": "npx",
      "args": ["-y", "@n8n/mcp@latest"]
    },
    "git-provenance": {
      "command": "npx",
      "args": ["-y", "@git/provenance-mcp@latest"]
    }
  },
  "recommendations": {
    "bug-fixing": ["context7"],
    "security-analysis": ["context7", "supabase"],
    "ui-development": ["shadcn", "playwright"],
    "database-operations": ["supabase"],
    "workflow-automation": ["n8n-mcp"],
    "code-quality": ["context7"],
    "testing": ["playwright", "context7"]
  }
}