{
  "workflow": "bug-management",
  "phase": "detection",
  "config": {
    "priority": "all",
    "categories": ["security", "performance", "runtime-errors", "dead-code", "debug-code"],
    "maxBugsPerRun": 100,
    "verifyOnly": false,
    "targetFiles": [
      "scripts/orchestration-tools/handle-webhooks.sh",
      "scripts/orchestration-tools/switch-mcp.sh",
      "scripts/agent-creation/create-agent.sh",
      "scripts/monitoring/standards-monitoring.sh"
    ],
    "focusAreas": [
      "Инъекция команд (command injection)",
      "Отсутствие валидации входных данных",
      "Уязвимости безопасности в shell-скриптах",
      "Hardcoded пути и конфигурации",
      "Небезопасное использование eval",
      "Отсутствие экранирования переменных"
    ]
  },
  "validation": {
    "required": ["report-exists"],
    "optional": ["no-new-bugs"]
  },
  "nextAgent": "bug-fixer",
  "metadata": {
    "created": "2026-03-08",
    "createdBy": "bug-orchestrator",
    "description": "Полный анализ безопасности скриптов проекта"
  }
}
