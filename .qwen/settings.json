{
  "security": {
    "folderTrust": {
      "enabled": true
    }
  },
  "$version": 3,
  "ui": {
    "theme": "ANSI",
    "showLineNumbers": true,
    "customWittyPhrases": [
      "Анализирую код как профессионал...",
      "Ищу лучшее решение...",
      "Оптимизирую для производительности...",
      "Проверяю best practices...",
      "Готовлю production-ready код..."
    ]
  },
  "general": {
    "outputLanguage": "Russian",
    "language": "ru",
    "vimMode": true,
    "preferredEditor": "neovim",
    "gitCoAuthor": true,
    "enableAutoUpdate": false,
    "checkpointing": {
      "enabled": true
    }
  },
  "tools": {
    "shell": {
      "enableInteractiveShell": true
    },
    "approvalMode": "default",
    "allowed": [
      "run_shell_command(git status)",
      "run_shell_command(git diff)",
      "run_shell_command(npm test)",
      "run_shell_command(npm run build)"
    ]
  },
  "ide": {
    "enabled": true
  },
  "experimental": {
    "skills": true,
    "vlmSwitchMode": "once"
  },
  "context": {
    "fileName": [
      "QWEN.md",
      "README.md",
      "CONTEXT.md",
      "constitution.md"
    ],
    "fileFiltering": {
      "respectGitIgnore": true,
      "respectQwenIgnore": true,
      "enableRecursiveFileSearch": true
    }
  },
  "sessionTokenLimit": 32000,
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--executable-path=/usr/bin/chromium",
        "--isolated"
      ]
    },
    "searxng": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-searxng@latest"
      ],
      "env": {
        "SEARXNG_URL": "http://localhost:8080"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem@latest",
        "/home/alex/MyProjects/qwen_orc_kit_ru"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git@latest"
      ],
      "cwd": "/home/alex/MyProjects/qwen_orc_kit_ru"
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github@latest"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-playwright@latest"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(cat)",
      "Bash(set *)",
      "Bash(log_info)",
      "Bash(})",
      "Bash(log_success)",
      "Bash(log_error)",
      "Bash(check_dependencies)",
      "Bash(log_info *)",
      "Bash(then)",
      "Bash(log_error *)",
      "Bash(exit *)",
      "Bash(fi)",
      "Bash(do)",
      "Bash(true)",
      "Bash(done)",
      "Bash(log_success *)",
      "Bash(generate_tasks)",
      "Bash(sed *)",
      "Bash(**версия:** *)",
      "Bash(**дата:** *)",
      "Bash(**статус:** *)",
      "Bash(**тип:** *)",
      "Bash(---)",
      "Bash(\\`\\`\\`)",
      "Bash(← *)",
      "Bash(↓)",
      "Bash(001-notes)",
      "Bash(002-search)",
      "Bash(003-export-import)",
      "Bash(**критический *)",
      "Bash(eof)",
      "Bash(cut *)",
      "Bash(echo *)",
      "Bash(- *)",
      "Bash(задача)",
      "Bash(требования)",
      "Bash(статус)",
      "Bash(приоритет)",
      "Bash(--------)",
      "Bash(------------)",
      "Bash(-----------)",
      "Bash(t-001)",
      "Bash(fr-001)",
      "Bash(pending)",
      "Bash(p0)",
      "Bash(main)",
      "Bash(main *)",
      "Bash(eofscript)",
      "Bash(chmod *)"
    ]
  }
}