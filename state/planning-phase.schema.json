{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Planning Phase Plan Schema",
  "description": "Schema for planning phase workflow plan files",
  "type": "object",
  "required": ["phase", "config"],
  "properties": {
    "phase": {
      "type": "number",
      "description": "Current phase of execution (should be 0 for planning phase)",
      "const": 0
    },
    "config": {
      "type": "object",
      "description": "Configuration for the planning phase",
      "required": ["priority", "scope"],
      "properties": {
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "Priority level for the planning tasks"
        },
        "scope": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Scope of files/directories to analyze during planning"
        }
      }
    },
    "validation": {
      "type": "object",
      "description": "Validation requirements for the planning phase",
      "properties": {
        "required": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Required validation checks that must pass"
        },
        "optional": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Optional validation checks"
        }
      }
    },
    "mcpGuidance": {
      "type": "object",
      "description": "Guidance for MCP server usage during planning",
      "properties": {
        "recommended": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Recommended MCP servers for this planning phase"
        },
        "library": {
          "type": "string",
          "description": "Library name for context7 lookups"
        },
        "reason": {
          "type": "string",
          "description": "Reason for MCP server recommendations"
        }
      }
    },
    "nextAgent": {
      "type": "string",
      "description": "Name of the next agent to execute after planning phase"
    },
    "planningTasks": {
      "type": "array",
      "description": "Specific planning tasks to be executed",
      "items": {
        "type": "object",
        "required": ["taskType", "description"],
        "properties": {
          "taskType": {
            "type": "string",
            "enum": ["taskAnalysis", "agentTypeDetermination", "executorAssignment", "dependencyMapping"],
            "description": "Type of planning task"
          },
          "description": {
            "type": "string",
            "description": "Description of the planning task"
          },
          "requiredAgent": {
            "type": "string",
            "description": "Required agent type to execute this task"
          },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"],
            "description": "Priority of this specific task"
          }
        }
      }
    }
  }
}